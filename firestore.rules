rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, createdAt, totalXP
    //
    // Collection: courses
    // Fields: title, description, icon, color, status, modulesCount, studentsCount, createdBy, createdAt
    //
    // Collection: modules
    // Fields: courseId, title, description, icon, color, status, quizzesCount, studentsCount, engagement, createdBy, createdAt
    //
    // Collection: quizzes
    // Fields: moduleId, title, description, timeLimit, questions, createdBy, createdAt
    //
    // Collection: results
    // Fields: quizId, studentId, score, totalQuestions, completedAt, xpEarned
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "muhammadtayyab2928@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt', 'totalXP']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student'];
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'status', 'createdBy']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.status in ['active', 'draft', 'archived'];
    }

    function isValidModule(data) {
      return data.keys().hasAll(['title', 'courseId', 'status', 'createdBy']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.courseId is string &&
             data.status in ['active', 'draft', 'archived'];
    }

    function isValidQuiz(data) {
      return data.keys().hasAll(['moduleId', 'title', 'questions']) &&
             data.title is string && data.title.size() > 0 &&
             data.questions is list;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['quizId', 'quizTitle', 'moduleId', 'studentId', 'score', 'earnedPoints', 'totalPoints', 'status', 'answers']) &&
             data.score is number && data.score >= 0 &&
             data.earnedPoints is number &&
             data.totalPoints is number &&
             data.status in ['passed', 'failed'] &&
             data.answers is map;
    }

    function isValidAchievement(data) {
      return data.keys().hasAll(['userId', 'achievementId', 'title', 'unlockedAt']) &&
             data.userId is string &&
             data.achievementId is string &&
             data.title is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'student' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && isValidCourse(request.resource.data);
    }

    match /modules/{moduleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && isValidModule(request.resource.data);
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && isValidQuiz(request.resource.data);
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentId && isValidResult(request.resource.data);
      allow update: if false; // Results should be immutable
      allow delete: if isAdmin();
    }

    match /user_achievements/{achievementId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidAchievement(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
