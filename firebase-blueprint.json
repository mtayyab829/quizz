{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "totalXP": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "A top-level course containing modules",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft", "archived"] },
        "modulesCount": { "type": "number" },
        "studentsCount": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "createdBy"]
    },
    "Module": {
      "title": "Module",
      "description": "A learning module containing quizzes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft", "archived"] },
        "quizzesCount": { "type": "number" },
        "studentsCount": { "type": "number" },
        "engagement": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "courseId", "status", "createdBy"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz within a module",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "moduleId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "timeLimit": { "type": "number" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "number" },
              "type": { "type": "string", "enum": ["multiple-choice", "true-false"] }
            }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["moduleId", "title", "questions"]
    },
    "QuizResult": {
      "title": "QuizResult",
      "description": "A student's attempt at a quiz",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quizId": { "type": "string" },
        "studentId": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" },
        "xpEarned": { "type": "number" }
      },
      "required": ["quizId", "studentId", "score"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Top-level courses"
    },
    "/modules/{moduleId}": {
      "schema": "Module",
      "description": "Learning modules"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Quizzes"
    },
    "/results/{resultId}": {
      "schema": "QuizResult",
      "description": "Student quiz results"
    }
  }
}
